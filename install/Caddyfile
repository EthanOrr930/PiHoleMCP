{
    admin off
}

:80 {
    redir / /admin permanent

    handle /mcp* {
        reverse_proxy 127.0.0.1:8473 {
            transport http {
                read_timeout 1h
                write_timeout 1h
            }
            flush_interval -1
        }
    }

    handle /admin* {
        reverse_proxy 127.0.0.1:8081
    }

    handle /api* {
        reverse_proxy 127.0.0.1:8081
    }

    handle {
        reverse_proxy 127.0.0.1:8081
    }

    log {
        output file /var/log/caddy/access.log {
            roll_size 10MB
            roll_keep 5
        }
        format json
    }
}
